# Normalise line endings: store LF in the repo, check out native on Windows.
* text=auto eol=lf

# Python
*.py text

# Docs / config
*.md   text
*.txt  text
*.cff  text
*.toml text
*.yml  text
*.yaml text

# Treat binaries as binary (never line-ending-converted or diffed as text)
*.png  binary
*.pdf  binary
*.npz  binary
*.parquet binary
*.tif  binary
*.geojson binary
